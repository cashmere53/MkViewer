{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MkViewer",
  "version": "0.1.0",
  "identifier": "com.mkviewer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MkViewer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
